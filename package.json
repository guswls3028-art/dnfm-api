{
  "name": "dnfm-api",
  "version": "0.1.0",
  "private": true,
  "description": "api.dnfm.kr — dnfm 사이트들의 공용 백엔드 (Hono + Drizzle + PostgreSQL + R2).",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "tsx ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx src/shared/db/migrate.ts",
    "db:seed": "tsx src/shared/db/seed.ts",
    "db:studio": "tsx ./node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@google-cloud/vision": "^4.3.2",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.4",
    "google-auth-library": "^9.15.0",
    "hono": "^4.6.14",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.30.1",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
