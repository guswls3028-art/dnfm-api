NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# PostgreSQL (docker-compose 기본값과 동일)
DATABASE_URL=postgresql://dnfm:dnfm@localhost:5432/dnfm

# 인증 — JWT secret. 운영에서는 SSM/secret manager 에서 주입.
# 최소 32자 권장. 개발용 임시값일 뿐, 운영 코드에 commit 금지.
JWT_ACCESS_SECRET=dev-access-secret-change-in-prod-32chars-min
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-prod-32chars-min
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# 쿠키 — sibling subdomain 공유
COOKIE_DOMAIN=.dnfm.kr
COOKIE_SECURE=false

# CORS 허용 Origin (콤마 구분)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://dnfm.kr,https://www.dnfm.kr,https://hurock.dnfm.kr,https://allow.dnfm.kr

# 비밀번호 정책
BCRYPT_ROUNDS=10
PASSWORD_MIN_LENGTH=4

# Cloudflare R2 (S3 호환)
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=dnfm-uploads
R2_PRESIGN_TTL_SECONDS=600

# 사이트 식별
ALLOWED_SITES=newb,hurock

# Google Cloud Vision API — 던파 OCR (3종 캡처)
# Service Account JSON 파일 경로 (운영) 또는 API key
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_VISION_API_KEY=
GEMINI_API_KEY=
# 개발 시 OCR provider 없이 가입 흐름 UI만 확인할 때만 true.
OCR_MOCK_ENABLED=false

# OAuth providers (Stage 2)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/auth/oauth/google/callback
KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=
KAKAO_OAUTH_REDIRECT_URI=http://localhost:4000/auth/oauth/kakao/callback
